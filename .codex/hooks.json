{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python 'F:\\Projetos\\raiox-neondash\\.codex\\hooks\\smart_bash_approver.py'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python 'F:\\Projetos\\raiox-neondash\\.codex\\hooks\\protect_files.py'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python 'F:\\Projetos\\raiox-neondash\\.codex\\hooks\\task_routing_guard.py'",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Read|Grep|Glob|Bash|Edit|Write|mcp__plugin_serena_serena__.*|mcp__tavily__.*|mcp__sequential-thinking__.*|mcp__stitch__.*|mcp__playwright__.*|mcp__claude_ai_Context7__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"decision\":{\"behavior\":\"allow\"}}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python 'F:\\Projetos\\raiox-neondash\\.codex\\hooks\\ultracite.py'",
            "timeout": 30,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python 'F:\\Projetos\\raiox-neondash\\.codex\\hooks\\session_context.py'",
            "timeout": 15,
            "statusMessage": "Loading AGENTS.md + project context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python 'F:\\Projetos\\raiox-neondash\\.codex\\hooks\\ultracite.py'",
            "timeout": 30,
            "statusMessage": "Running lint check..."
          }
        ]
      }
    ]
  }
}
