---
import Layout from "../../layouts/Layout.astro";
import {
	getAdminAuthConfigStatus,
	readAdminSession,
} from "../../lib/server/auth";

export const prerender = false;

const session = await readAdminSession(Astro.cookies);
if (session) return Astro.redirect("/admin/leads");

const authStatus = getAdminAuthConfigStatus();
const error = Astro.url.searchParams.get("error");
---

<Layout
	title="Admin Raio-X | Grupo US"
	description="Acesso administrativo aos leads do Raio-X."
	noIndex={true}
	withAnalytics={false}
	bodyClass="bg-navy"
>
	<section class="mx-auto flex min-h-screen w-full max-w-md flex-col justify-center px-4 py-16">
		<div class="glass-card rounded-2xl p-6 sm:p-8">
			<p class="text-sm font-semibold uppercase tracking-[0.16em] text-gold">
				Admin
			</p>
			<h1 class="mt-3 font-serif text-3xl leading-tight text-foreground">
				Entrar no painel Raio-X
			</h1>
			<p class="mt-3 text-sm leading-relaxed text-muted">
				Acesso restrito para visualizar leads capturados e exportar a base.
			</p>

			{
				!authStatus.configured && (
					<div class="mt-6 rounded-lg border border-gold/40 bg-gold-soft p-4 text-sm leading-relaxed text-foreground">
						Configure as variáveis ADMIN_USERNAME, ADMIN_PASSWORD_SHA256 e
						ADMIN_SESSION_SECRET para liberar o login.
					</div>
				)
			}
			{
				error && (
					<div class="mt-6 rounded-lg border border-red-400/50 bg-red-500/10 p-4 text-sm text-red-100">
						Usuário ou senha inválidos.
					</div>
				)
			}

			<form method="post" action="/api/admin/login" class="mt-8 space-y-4">
				<label class="block">
					<span class="text-sm font-semibold text-foreground">Usuário</span>
					<input
						name="username"
						autocomplete="username"
						required
						class="mt-2 min-h-[48px] w-full rounded-lg border border-gold/20 bg-navy-light px-4 py-3 text-base text-foreground placeholder:text-muted/70"
					/>
				</label>
				<label class="block">
					<span class="text-sm font-semibold text-foreground">Senha</span>
					<input
						type="password"
						name="password"
						autocomplete="current-password"
						required
						class="mt-2 min-h-[48px] w-full rounded-lg border border-gold/20 bg-navy-light px-4 py-3 text-base text-foreground placeholder:text-muted/70"
					/>
				</label>
				<button
					type="submit"
					class="inline-flex min-h-[48px] w-full items-center justify-center rounded-lg bg-gold px-6 py-3 text-base font-semibold text-navy transition-colors hover:bg-gold-light"
				>
					Entrar
				</button>
			</form>
		</div>
	</section>
</Layout>
