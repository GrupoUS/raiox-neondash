---
import Layout from "../../layouts/Layout.astro";
import { readAdminSession } from "../../lib/server/auth";
import {
	getLeadStoreConfigStatus,
	listLeads,
} from "../../lib/server/leads-store";
import { whatsappUrlForLead } from "../../lib/whatsapp";

export const prerender = false;

const session = await readAdminSession(Astro.cookies);
if (!session) return Astro.redirect("/admin");

const storeStatus = getLeadStoreConfigStatus();
const leads = storeStatus.configured ? await listLeads(150) : [];
const partialLeads = leads.filter((lead) => lead.status === "partial");
const completedLeads = leads.filter((lead) => lead.status === "completed");
const hotLeads = leads.filter((lead) => lead.score?.intent === "hot");

const formatDate = (value?: string) =>
	value
		? new Intl.DateTimeFormat("pt-BR", {
				dateStyle: "short",
				timeStyle: "short",
				timeZone: "America/Sao_Paulo",
			}).format(new Date(value))
		: "-";

const segmentLabel: Record<string, string> = {
	"gargalo-gestao": "Gestão",
	"gargalo-marketing": "Marketing",
	"gargalo-vendas": "Vendas",
	"gargalos-distribuidos": "Distribuído",
};
---

<Layout
	title="Leads Raio-X | Grupo US"
	description="Painel administrativo dos leads capturados no Raio-X."
	noIndex={true}
	withAnalytics={false}
	bodyClass="bg-navy"
>
	<section class="min-h-screen px-4 py-8 sm:py-10">
		<div class="mx-auto w-full max-w-7xl">
			<header class="flex flex-col gap-4 border-b border-gold/20 pb-6 sm:flex-row sm:items-end sm:justify-between">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.16em] text-gold">
						Admin Raio-X
					</p>
					<h1 class="mt-2 font-serif text-3xl leading-tight text-foreground sm:text-4xl">
						Leads capturados
					</h1>
					<p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted sm:text-base">
						Visualize quem deixou contato, quem concluiu o quiz e qual gargalo
						principal apareceu no diagnóstico.
					</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<a
						href="/api/admin/leads.csv"
						class="inline-flex min-h-[44px] items-center justify-center rounded-lg border border-gold px-4 py-2 text-sm font-semibold text-gold transition-colors hover:bg-gold hover:text-navy"
					>
						Baixar CSV
					</a>
					<form method="post" action="/api/admin/logout">
						<button
							type="submit"
							class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-gold px-4 py-2 text-sm font-semibold text-navy transition-colors hover:bg-gold-light"
						>
							Sair
						</button>
					</form>
				</div>
			</header>

			{
				!storeStatus.configured && (
					<div class="mt-6 rounded-xl border border-gold/40 bg-gold-soft p-5 text-sm leading-relaxed text-foreground">
						Configure UPSTASH_REDIS_REST_URL e UPSTASH_REDIS_REST_TOKEN para
						armazenar e listar os leads.
					</div>
				)
			}

			<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				<div class="glass-card rounded-xl p-5">
					<p class="text-sm text-muted">Total</p>
					<p class="mt-2 text-3xl font-semibold text-foreground">{leads.length}</p>
				</div>
				<div class="glass-card rounded-xl p-5">
					<p class="text-sm text-muted">Parciais</p>
					<p class="mt-2 text-3xl font-semibold text-foreground">
						{partialLeads.length}
					</p>
				</div>
				<div class="glass-card rounded-xl p-5">
					<p class="text-sm text-muted">Finalizados</p>
					<p class="mt-2 text-3xl font-semibold text-foreground">
						{completedLeads.length}
					</p>
				</div>
				<div class="glass-card rounded-xl p-5">
					<p class="text-sm text-muted">Hot</p>
					<p class="mt-2 text-3xl font-semibold text-foreground">
						{hotLeads.length}
					</p>
				</div>
			</div>

			<div class="mt-6 overflow-hidden rounded-xl border border-gold/20 bg-navy-light/40">
				<div class="overflow-x-auto">
					<table class="min-w-full border-collapse text-left text-sm">
						<thead class="bg-navy-light text-xs uppercase tracking-[0.12em] text-muted">
							<tr>
								<th class="px-4 py-3">Lead</th>
								<th class="px-4 py-3">Status</th>
								<th class="px-4 py-3">Contato</th>
								<th class="px-4 py-3">Score</th>
								<th class="px-4 py-3">Gargalo</th>
								<th class="px-4 py-3">Atualizado</th>
								<th class="px-4 py-3">Ação</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-gold/10">
							{
								leads.map((lead) => {
									const leadMessage = `Olá, ${lead.contact.name}! Aqui é a Laura do Grupo US. Vi seu interesse na Sessão Raio-X e quero te ajudar a agendar.`;
									return (
										<tr class="align-top text-foreground">
											<td class="px-4 py-4">
												<p class="font-semibold">{lead.contact.name}</p>
												<p class="mt-1 text-xs text-muted">{lead.id}</p>
												<p class="mt-1 text-xs text-muted">
													Entrada: {formatDate(lead.createdAt)}
												</p>
											</td>
											<td class="px-4 py-4">
												<span class="inline-flex rounded-full border border-gold/30 px-3 py-1 text-xs font-semibold text-gold">
													{lead.status === "completed" ? "Finalizado" : "Parcial"}
												</span>
											</td>
											<td class="px-4 py-4 text-muted">
												<p>{lead.contact.whatsapp}</p>
												<p>{lead.contact.email}</p>
												<p>{lead.contact.instagram || "-"}</p>
												<p>{lead.contact.cityState || "-"}</p>
											</td>
											<td class="px-4 py-4">
												{lead.score ? (
													<>
														<p class="font-semibold">{lead.score.total}/100</p>
														<p class="text-xs uppercase text-muted">
															{lead.score.intent}
														</p>
													</>
												) : (
													<span class="text-muted">Pendente</span>
												)}
											</td>
											<td class="px-4 py-4 text-muted">
												{lead.score
													? segmentLabel[lead.score.segment] ?? lead.score.segment
													: "-"}
											</td>
											<td class="px-4 py-4 text-muted">
												{formatDate(lead.updatedAt)}
											</td>
											<td class="px-4 py-4">
												<a
													href={whatsappUrlForLead(lead.contact.whatsapp, leadMessage)}
													target="_blank"
													rel="noopener noreferrer"
													class="inline-flex min-h-[40px] items-center justify-center rounded-lg bg-gold px-3 py-2 text-xs font-semibold text-navy transition-colors hover:bg-gold-light"
												>
													Chamar lead
												</a>
											</td>
										</tr>
									);
								})
							}
							{
								leads.length === 0 && (
									<tr>
										<td colspan="7" class="px-4 py-10 text-center text-muted">
											Nenhum lead armazenado ainda.
										</td>
									</tr>
								)
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</section>
</Layout>
