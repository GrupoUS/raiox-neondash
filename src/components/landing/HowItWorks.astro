---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { FileText, MapPin, MessageCircle, Video } from "lucide-react";

interface Step {
	number: string;
	title: string;
	description: string;
	duration?: string;
}

interface Props {
	headline: string;
	subhead?: string;
	image?: {
		src: ImageMetadata;
		alt: string;
		objectPosition?: string;
	};
	steps: Step[];
}

const { headline, subhead, image, steps } = Astro.props;

const STEP_ICONS = [FileText, MessageCircle, Video, MapPin] as const;
---

<section class="py-20 md:py-24 px-6 lg:px-8">
	<div class="max-w-6xl mx-auto">
		<header class="text-center mb-10 md:mb-14">
			<h2
				class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4"
				data-reveal="up"
			>
				<span class="text-gradient-gold">{headline}</span>
			</h2>
			{
				subhead && (
					<p
						class="text-base md:text-lg text-muted max-w-2xl mx-auto"
						data-reveal="up"
						data-reveal-delay="1"
					>
						{subhead}
					</p>
				)
			}
		</header>

		{
			image && (
				<div
					class="relative mx-auto mb-12 md:mb-16 max-w-2xl aspect-[16/10] rounded-2xl overflow-hidden ring-1 ring-gold/20 shadow-2xl"
					data-reveal="up"
					data-reveal-delay="1"
				>
					<Image
						src={image.src}
						alt={image.alt}
						widths={[480, 720, 960]}
						sizes="(max-width: 768px) 90vw, 640px"
						loading="lazy"
						class="w-full h-full object-cover"
						style={`object-position: ${image.objectPosition ?? "center top"};`}
					/>
					<div
						class="absolute inset-0 bg-gradient-to-t from-navy/50 via-transparent to-transparent pointer-events-none"
						aria-hidden="true"
					></div>
				</div>
			)
		}

		<ol class="relative grid grid-cols-1 lg:grid-cols-4 gap-8 lg:gap-6 list-none">
			<div
				class="hidden lg:block absolute top-7 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent pointer-events-none"
				aria-hidden="true"
			></div>

			{
				steps.map((step, index) => {
					const Icon = STEP_ICONS[index] ?? FileText;
					return (
						<li
							class="relative group"
							data-reveal="up"
							data-reveal-delay={String(Math.min(index + 1, 6))}
						>
							<div class="flex lg:flex-col lg:items-center gap-4 lg:gap-0 lg:text-center">
								<div class="relative shrink-0 lg:mx-auto lg:mb-5">
									{index < steps.length - 1 && (
										<span
											class="lg:hidden absolute left-1/2 -translate-x-1/2 top-full mt-1 w-px h-[calc(2rem+1.5rem)] bg-gradient-to-b from-gold/40 to-gold/0 pointer-events-none"
											aria-hidden="true"
										/>
									)}
									<div class="relative z-10 size-14 lg:size-16 rounded-full bg-navy ring-2 ring-gold flex items-center justify-center text-gold shadow-lg shadow-gold/20">
										<Icon aria-hidden="true" width={24} height={24} />
									</div>
									<span
										class="absolute -top-2 -right-2 lg:left-1/2 lg:-translate-x-1/2 lg:-top-3 lg:right-auto z-20 font-serif text-base lg:text-2xl font-bold text-gold/60 leading-none px-1.5 py-0.5 lg:p-0 rounded-full lg:rounded-none bg-navy lg:bg-transparent"
										aria-hidden="true"
									>
										{step.number}
									</span>
								</div>

								<div class="flex-1 min-w-0 lg:max-w-xs">
									{step.duration && (
										<span class="inline-flex items-center px-3 py-1 mb-3 rounded-full bg-gold-soft text-gold text-[11px] font-semibold tracking-[0.14em] uppercase ring-1 ring-gold/30">
											{step.duration}
										</span>
									)}
									<h3 class="font-serif text-xl lg:text-2xl font-bold text-foreground mb-2 leading-tight">
										{step.title}
									</h3>
									<p class="text-sm md:text-base text-muted leading-relaxed">
										{step.description}
									</p>
								</div>
							</div>
						</li>
					);
				})
			}
		</ol>
	</div>
</section>
