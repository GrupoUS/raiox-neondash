---
import { CheckCircle2, XCircle } from "lucide-react";

interface Props {
	headline: string;
	intro?: string;
	items: string[];
	variant: "fit" | "not-fit";
}

const { headline, intro, items, variant } = Astro.props;

const isFit = variant === "fit";
const Icon = isFit ? CheckCircle2 : XCircle;
const containerClass = isFit
	? "bg-fit-column ring-1 ring-success/30"
	: "bg-not-fit-column ring-1 ring-navy/10";
const introTextClass = isFit ? "text-navy/70" : "text-navy/60";
const iconClass = isFit ? "text-success" : "text-navy/45";
const itemTextClass = isFit ? "text-navy" : "text-navy/75";
const revealDelay = isFit ? undefined : "1";
---

<div
	class={`text-navy rounded-2xl p-8 lg:p-10 h-full shadow-xl ${containerClass}`}
	data-reveal="up"
	data-reveal-delay={revealDelay}
>
	<h2 class="font-serif text-2xl md:text-3xl lg:text-4xl font-bold mb-4 text-navy">
		{headline}
	</h2>

	{
		intro && (
			<p class={`text-base md:text-lg mb-8 ${introTextClass}`}>
				{intro}
			</p>
		)
	}

	<ul class="space-y-4 list-none">
		{
			items.map((item, index) => (
				<li
					class="flex items-start gap-3"
					data-reveal="up"
					data-reveal-delay={String(Math.min(index + 2, 6))}
				>
					<span class={`shrink-0 mt-0.5 ${iconClass}`} aria-hidden="true">
						<Icon width={22} height={22} strokeWidth={isFit ? 2.2 : 2} />
					</span>
					<p class={`text-base md:text-[1.0625rem] leading-relaxed ${itemTextClass}`}>
						{item}
					</p>
				</li>
			))
		}
	</ul>
</div>
