---
import { CheckCircle2, XCircle } from "lucide-react";

interface Props {
	headline: string;
	intro?: string;
	items: string[];
	variant: "fit" | "not-fit";
}

const { headline, intro, items, variant } = Astro.props;

const isFit = variant === "fit";
const Icon = isFit ? CheckCircle2 : XCircle;
const ringClass = isFit ? "ring-1 ring-success/40" : "ring-1 ring-gold/15";
const accentBarStyle = isFit
	? "bg-gradient-to-b from-success via-success/60 to-transparent"
	: "bg-gradient-to-b from-gold/60 via-gold/20 to-transparent";
const iconClass = isFit ? "text-success" : "text-muted";
const itemTextClass = isFit ? "text-foreground" : "text-foreground/75";
const introClass = isFit ? "text-foreground/80" : "text-muted";
const revealDelay = isFit ? undefined : "1";
---

<div
	class={`relative glass-card rounded-2xl p-8 lg:p-10 h-full overflow-hidden ${ringClass}`}
	data-reveal="up"
	data-reveal-delay={revealDelay}
>
	<span
		class={`absolute left-0 top-6 bottom-6 w-1 rounded-r-full ${accentBarStyle}`}
		aria-hidden="true"
	></span>

	<h2 class="font-serif text-2xl md:text-3xl lg:text-4xl font-bold mb-4">
		<span class={isFit ? "text-foreground" : "text-gradient-gold"}>
			{headline}
		</span>
	</h2>

	{
		intro && (
			<p class={`text-base md:text-lg mb-8 ${introClass}`}>
				{intro}
			</p>
		)
	}

	<ul class="space-y-4 list-none">
		{
			items.map((item, index) => (
				<li
					class="flex items-start gap-3"
					data-reveal="up"
					data-reveal-delay={String(Math.min(index + 2, 6))}
				>
					<span class={`shrink-0 mt-0.5 ${iconClass}`} aria-hidden="true">
						<Icon width={22} height={22} strokeWidth={isFit ? 2.2 : 2} />
					</span>
					<p class={`text-base md:text-[1.0625rem] leading-relaxed ${itemTextClass}`}>
						{item}
					</p>
				</li>
			))
		}
	</ul>
</div>
