---
import { X } from "lucide-react";

interface Props {
	headline: string;
	intro?: string;
	items: string[];
}

const { headline, intro, items } = Astro.props;
---

<section class="py-20 md:py-24 px-6 lg:px-8">
	<div class="max-w-3xl mx-auto">
		<h2
			class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-center leading-tight mb-4"
			data-reveal="up"
		>
			<span class="text-gradient-gold">{headline}</span>
		</h2>

		{
			intro && (
				<p
					class="text-base md:text-lg text-muted text-center mb-10"
					data-reveal="up"
					data-reveal-delay="1"
				>
					{intro}
				</p>
			)
		}

		<ul class="space-y-4 list-none">
			{
				items.map((item, index) => (
					<li
						class="flex items-start gap-4 rounded-xl border border-navy-lighter bg-navy-light/40 px-5 py-4"
						data-reveal="up"
						data-reveal-delay={String(Math.min(index + 2, 6))}
					>
						<span
							class="shrink-0 mt-0.5 size-6 rounded-full border border-gold/30 flex items-center justify-center text-gold"
							aria-hidden="true"
						>
							<X width={14} height={14} />
						</span>
						<p class="text-sm md:text-base text-muted leading-relaxed">
							{item}
						</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
