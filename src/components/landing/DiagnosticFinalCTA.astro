---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { ArrowRight, MessageCircle, Star } from "lucide-react";
import {
	WHATSAPP_DEFAULT_SITE_MESSAGE,
	whatsappUrlWithText,
} from "../../lib/whatsapp";
import Button from "../shared/Button.astro";

interface FinalCtaData {
	headline: string;
	paragraphs: string[];
	cta: {
		label: string;
		microcopy?: string;
	};
	secondaryCta?: {
		label: string;
		whatsappMessage: string;
	};
	image?: {
		src: ImageMetadata;
		alt: string;
		objectPosition?: string;
	};
	socialProof?: {
		stars?: number;
		text: string;
	};
}

interface Props {
	finalCta: FinalCtaData;
	primaryCtaUrl: string;
}

const { finalCta, primaryCtaUrl } = Astro.props;

const secondaryHref = finalCta.secondaryCta
	? whatsappUrlWithText(finalCta.secondaryCta.whatsappMessage)
	: whatsappUrlWithText(WHATSAPP_DEFAULT_SITE_MESSAGE);

const starCount = finalCta.socialProof?.stars ?? 5;
const starsArray = Array.from({ length: starCount });
---

<section
	class="relative overflow-hidden py-20 sm:py-24 md:py-28 lg:py-32 px-5 sm:px-6 lg:px-8 bg-gradient-to-b from-navy via-navy-light to-navy"
>
	<div class="absolute inset-0 pointer-events-none" aria-hidden="true">
		<div
			class="absolute top-0 left-1/2 -translate-x-1/2 w-[640px] h-[640px] rounded-full bg-gold-soft blur-3xl opacity-40"
		>
		</div>
	</div>

	<div class="relative max-w-5xl lg:max-w-6xl mx-auto">
		<div
			class="glass-card-bright rounded-3xl p-8 md:p-12 lg:p-16"
			data-reveal="scale"
		>
			<div
				class="grid grid-cols-1 lg:grid-cols-[auto_1.4fr] gap-8 lg:gap-14 items-center"
			>
				{
					finalCta.image && (
						<div
							class="mx-auto lg:mx-0"
							data-reveal="up"
							data-reveal-delay="1"
						>
							<div class="relative w-40 h-40 md:w-48 md:h-48 lg:w-72 lg:h-72 rounded-full overflow-hidden ring-2 ring-gold/50 shadow-2xl shadow-gold/10">
								<Image
									src={finalCta.image.src}
									alt={finalCta.image.alt}
									widths={[224, 320, 448, 576]}
									sizes="(max-width: 768px) 160px, (max-width: 1024px) 192px, 288px"
									loading="lazy"
									class="w-full h-full object-cover"
									style={`object-position: ${finalCta.image.objectPosition ?? "center top"};`}
								/>
							</div>
						</div>
					)
				}

				<div class="text-center lg:text-left">
					<h2
						class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold mb-6"
						data-reveal="up"
						data-reveal-delay="1"
					>
						<span class="text-shimmer">{finalCta.headline}</span>
					</h2>

					<div
						class="space-y-4 mb-8 max-w-xl mx-auto lg:mx-0"
						data-reveal="up"
						data-reveal-delay="2"
					>
						{
							finalCta.paragraphs.map((paragraph) => (
								<p class="text-base md:text-lg text-foreground/90 leading-relaxed">
									{paragraph}
								</p>
							))
						}
					</div>

					<div
						class="flex flex-col items-center lg:items-start gap-4"
						data-reveal="up"
						data-reveal-delay="3"
					>
						<div class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto">
							<Button
								variant="primary"
								size="lg"
								href={primaryCtaUrl}
								glow={true}
								dataCtaLocation="finalCta"
								ariaLabel={finalCta.cta.label}
							>
								<span>{finalCta.cta.label}</span>
								<ArrowRight aria-hidden="true" width={20} height={20} />
							</Button>

							{
								finalCta.secondaryCta && (
									<Button
										variant="outline"
										size="lg"
										href={secondaryHref}
										target="_blank"
										dataCtaLocation="finalCta"
										ariaLabel={finalCta.secondaryCta.label}
									>
										<MessageCircle aria-hidden="true" width={18} height={18} />
										<span>{finalCta.secondaryCta.label}</span>
									</Button>
								)
							}
						</div>

						{
							finalCta.cta.microcopy && (
								<p class="text-sm text-muted">
									{finalCta.cta.microcopy}
								</p>
							)
						}

						{
							finalCta.socialProof && (
								<div class="flex items-center gap-2 mt-2">
									<span class="flex items-center gap-0.5 text-gold" aria-hidden="true">
										{starsArray.map(() => (
											<Star width={16} height={16} fill="currentColor" strokeWidth={0} />
										))}
									</span>
									<span class="text-sm text-foreground/80">
										{finalCta.socialProof.text}
									</span>
								</div>
							)
						}

						<p class="text-sm text-muted mt-3 max-w-md leading-relaxed">
							Ao continuar, você aceita nossa{" "}
							<a
								href="/politica-de-privacidade"
								class="underline underline-offset-2 hover:text-gold transition-colors"
							>
								política de privacidade
							</a>
							.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
