---
import {
	Lightbulb,
	Map as MapIcon,
	Stethoscope,
	Target,
	Users,
} from "lucide-react";

const ICONS = {
	Stethoscope,
	Target,
	Lightbulb,
	Map: MapIcon,
	Users,
} as const;

type IconKey = keyof typeof ICONS;

interface BenefitItem {
	icon: string;
	title: string;
	description?: string;
}

interface Props {
	headline: string;
	items: BenefitItem[];
}

const { headline, items } = Astro.props;

function resolveIcon(name: string) {
	return name in ICONS ? ICONS[name as IconKey] : Lightbulb;
}
---

<section class="py-20 md:py-24 px-6 lg:px-8">
	<div class="max-w-4xl mx-auto">
		<h2
			class="font-[family-name:var(--font-serif)] text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-12 md:mb-16"
			data-reveal="up"
		>
			<span class="text-gradient-gold">{headline}</span>
		</h2>

		<ul class="space-y-5 md:space-y-6 list-none">
			{
				items.map((item, index) => {
					const Icon = resolveIcon(item.icon);
					return (
						<li
							class="glass-card card-hover-lift rounded-2xl p-6 md:p-7 flex items-start gap-5"
							data-reveal="up"
							data-reveal-delay={String(Math.min(index + 1, 6))}
						>
							<div class="shrink-0 size-12 rounded-full bg-[color-mix(in_srgb,var(--color-gold)_15%,transparent)] flex items-center justify-center text-[var(--color-gold)]">
								<Icon aria-hidden="true" width={24} height={24} />
							</div>
							<div class="flex-1 min-w-0">
								<h3 class="text-lg md:text-xl font-semibold text-[var(--color-text-primary)] mb-1.5">
									{item.title}
								</h3>
								{item.description && (
									<p class="text-sm md:text-base text-[var(--color-text-muted)] leading-relaxed">
										{item.description}
									</p>
								)}
							</div>
						</li>
					);
				})
			}
		</ul>
	</div>
</section>
