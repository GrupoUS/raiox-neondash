---
import {
	Lightbulb,
	Map as MapIcon,
	Stethoscope,
	Target,
	Users,
} from "lucide-react";

const ICONS = {
	Stethoscope,
	Target,
	Lightbulb,
	Map: MapIcon,
	Users,
} as const;

type IconKey = keyof typeof ICONS;

interface BenefitItem {
	icon: string;
	title: string;
	description?: string;
}

interface Props {
	headline: string;
	items: BenefitItem[];
}

const { headline, items } = Astro.props;

function resolveIcon(name: string) {
	return name in ICONS ? ICONS[name as IconKey] : Lightbulb;
}
---

<section class="py-20 md:py-24 px-6 lg:px-8">
	<div class="max-w-4xl mx-auto">
		<h2
			class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-12 md:mb-16"
			data-reveal="up"
		>
			<span class="text-gradient-gold">{headline}</span>
		</h2>

		<ul class="space-y-5 md:space-y-6 list-none">
			{
				items.map((item, index) => {
					const Icon = resolveIcon(item.icon);
					return (
						<li
							class="relative bg-navy-light/40 border-l-4 border-gold rounded-r-2xl rounded-l-sm p-6 md:p-7 flex items-start gap-5 transition-colors duration-200 hover:bg-navy-light/60"
							data-reveal="up"
							data-reveal-delay={String(Math.min(index + 1, 6))}
						>
							<div class="shrink-0 size-12 rounded-full bg-gold-soft flex items-center justify-center text-gold ring-1 ring-gold/30">
								<Icon aria-hidden="true" width={28} height={28} />
							</div>
							<div class="flex-1 min-w-0">
								<h3 class="font-serif text-xl md:text-2xl font-bold text-foreground mb-1.5">
									{item.title}
								</h3>
								{item.description && (
									<p class="text-sm md:text-base text-muted leading-relaxed">
										{item.description}
									</p>
								)}
							</div>
						</li>
					);
				})
			}
		</ul>
	</div>
</section>
