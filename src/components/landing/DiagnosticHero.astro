---
import { ArrowRight } from "lucide-react";
import Button from "../shared/Button.astro";

interface HeroData {
	eyebrow?: string;
	headline: string;
	tagline: string;
	subhead: string;
	cta: {
		label: string;
		helperText?: string;
	};
	trustSignals?: {
		urgencyMicrocopy?: string;
	};
}

interface Props {
	hero: HeroData;
	primaryCtaUrl: string;
}

const { hero, primaryCtaUrl } = Astro.props;
---

<section class="landing-mesh-bg relative overflow-hidden">
	<div class="max-w-5xl mx-auto px-6 lg:px-8 py-20 md:py-28 lg:py-32 text-center">
		{
			hero.eyebrow && (
				<p
					class="text-sm md:text-base font-medium uppercase tracking-[0.2em] text-[var(--color-gold)] mb-6"
					data-reveal="up"
				>
					{hero.eyebrow}
				</p>
			)
		}

		<h1
			class="font-[family-name:var(--font-serif)] text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight mb-6"
			data-reveal="up"
			data-reveal-delay="1"
		>
			<span class="text-shimmer">{hero.headline}</span>
		</h1>

		<p
			class="text-xl md:text-2xl font-medium text-[var(--color-text-primary)] mb-5 max-w-3xl mx-auto"
			data-reveal="up"
			data-reveal-delay="2"
		>
			{hero.tagline}
		</p>

		<p
			class="text-base md:text-lg text-[var(--color-text-muted)] leading-relaxed mb-10 max-w-2xl mx-auto"
			data-reveal="up"
			data-reveal-delay="3"
		>
			{hero.subhead}
		</p>

		<div
			class="flex flex-col items-center gap-3"
			data-reveal="up"
			data-reveal-delay="4"
		>
			<Button
				variant="primary"
				size="lg"
				href={primaryCtaUrl}
				glow={true}
				dataCtaLocation="hero"
				ariaLabel={hero.cta.label}
			>
				<span>{hero.cta.label}</span>
				<ArrowRight aria-hidden="true" width={20} height={20} />
			</Button>

			{
				hero.cta.helperText && (
					<p class="text-sm text-[var(--color-text-muted)]">
						{hero.cta.helperText}
					</p>
				)
			}

			{
				hero.trustSignals?.urgencyMicrocopy && (
					<p class="text-xs uppercase tracking-[0.18em] text-[var(--color-gold-light)] mt-2">
						{hero.trustSignals.urgencyMicrocopy}
					</p>
				)
			}
		</div>
	</div>
</section>
