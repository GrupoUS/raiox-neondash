---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import {
	ArrowRight,
	Clock,
	MessageCircle,
	Sparkles,
	Stethoscope,
} from "lucide-react";
import Button from "../shared/Button.astro";

interface TrustStripItem {
	icon: string;
	label: string;
	value: string;
}

interface HeroData {
	eyebrow?: string;
	headline: string;
	headlineParts?: {
		lead: string;
		highlight: string;
		tail?: string;
	};
	tagline: string;
	subhead: string;
	problemPills?: string[];
	cta: {
		label: string;
		helperText?: string;
	};
	image?: {
		src: ImageMetadata;
		alt: string;
		priority?: boolean;
		objectPosition?: string;
	};
	trustSignals?: {
		urgencyMicrocopy?: string;
	};
	trustStrip?: TrustStripItem[];
}

interface Props {
	hero: HeroData;
	primaryCtaUrl: string;
}

const { hero, primaryCtaUrl } = Astro.props;
const heroImage = hero.image;

const TRUST_ICONS = {
	Clock,
	MessageCircle,
	Stethoscope,
	Sparkles,
} as const;

type TrustIconKey = keyof typeof TRUST_ICONS;

function resolveTrustIcon(name: string) {
	return name in TRUST_ICONS ? TRUST_ICONS[name as TrustIconKey] : Sparkles;
}
---

<section class="landing-mesh-bg relative overflow-hidden">
	<div
		class="scanner-grid-bg absolute inset-0 pointer-events-none opacity-60"
		aria-hidden="true"
	></div>

	<div
		class="relative max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-12 sm:py-16 md:py-24 lg:py-28"
	>
		<div
			class="grid grid-cols-1 lg:grid-cols-5 gap-8 sm:gap-10 lg:gap-14 items-center"
		>
			<div class="lg:col-span-3 text-center lg:text-left">
				{
					hero.eyebrow && (
						<p
							class="text-sm md:text-base font-medium uppercase tracking-[0.2em] text-gold mb-5 sm:mb-6"
							data-reveal="up"
						>
							{hero.eyebrow}
						</p>
					)
				}

				<h1
					class="font-serif font-bold leading-[1.02] tracking-tight mb-5 sm:mb-6 text-[2.25rem] sm:text-5xl md:text-6xl lg:text-[72px] xl:text-[88px]"
					data-reveal="up"
					data-reveal-delay="1"
				>
					{
						hero.headlineParts ? (
							<>
								<span class="text-foreground">{hero.headlineParts.lead}</span>
								<span class="text-gradient-gold"> {hero.headlineParts.highlight}</span>
								{hero.headlineParts.tail && (
									<span class="text-foreground"> {hero.headlineParts.tail}</span>
								)}
							</>
						) : (
							<span class="text-shimmer">{hero.headline}</span>
						)
					}
				</h1>

				<p
					class="text-lg sm:text-xl md:text-2xl font-medium text-foreground mb-4 sm:mb-5 max-w-2xl lg:mx-0 mx-auto"
					data-reveal="up"
					data-reveal-delay="2"
				>
					{hero.tagline}
				</p>

				<p
					class="text-base md:text-lg text-muted leading-relaxed mb-6 sm:mb-7 max-w-xl lg:mx-0 mx-auto"
					data-reveal="up"
					data-reveal-delay="3"
				>
					{hero.subhead}
				</p>

				{
					hero.problemPills && hero.problemPills.length > 0 && (
						<ul
							class="flex flex-wrap items-center justify-center lg:justify-start gap-2 mb-7 sm:mb-8 list-none"
							data-reveal="up"
							data-reveal-delay="3"
						>
							{hero.problemPills.map((pill) => (
								<li class="rounded-full border border-gold/30 bg-gold-soft px-3.5 py-1.5 text-[0.78rem] sm:text-xs uppercase tracking-[0.14em] text-gold-light">
									{pill}
								</li>
							))}
						</ul>
					)
				}

				<div
					class="flex flex-col items-center lg:items-start gap-3"
					data-reveal="up"
					data-reveal-delay="4"
				>
					<Button
						variant="primary"
						size="lg"
						href={primaryCtaUrl}
						glow={true}
						dataCtaLocation="hero"
						ariaLabel={hero.cta.label}
					>
						<span>{hero.cta.label}</span>
						<ArrowRight aria-hidden="true" width={20} height={20} />
					</Button>

					{
						hero.cta.helperText && (
							<p class="text-sm text-muted">{hero.cta.helperText}</p>
						)
					}

					{
						hero.trustSignals?.urgencyMicrocopy && (
							<p class="inline-flex items-center gap-2 text-[0.78rem] sm:text-xs uppercase tracking-[0.18em] text-gold-light mt-1">
								<span
									class="size-1.5 rounded-full bg-gold animate-pulse"
									aria-hidden="true"
								/>
								{hero.trustSignals.urgencyMicrocopy}
							</p>
						)
					}
				</div>

				{
					hero.trustStrip && hero.trustStrip.length === 3 && (
						<ul
							class="grid grid-cols-3 gap-2 sm:gap-3 lg:gap-4 mt-8 sm:mt-10 lg:mt-12 list-none max-w-md lg:max-w-xl mx-auto lg:mx-0"
							data-reveal="up"
							data-reveal-delay="5"
						>
							{hero.trustStrip.map((item) => {
								const Icon = resolveTrustIcon(item.icon);
								return (
									<li class="relative rounded-xl bg-navy-light/50 border border-gold/15 px-2.5 py-3 sm:px-3 sm:py-3.5 lg:px-4 lg:py-4 flex flex-col items-center text-center gap-1.5 lg:gap-2 transition-colors duration-200 hover:border-gold/40 hover:bg-navy-light/70">
										<span class="text-gold" aria-hidden="true">
											<Icon width={18} height={18} />
										</span>
										<span class="text-[0.7rem] sm:text-[0.72rem] lg:text-[0.78rem] uppercase tracking-[0.1em] text-muted leading-none">
											{item.label}
										</span>
										<span class="text-[0.82rem] sm:text-sm lg:text-base font-semibold text-foreground leading-tight">
											{item.value}
										</span>
									</li>
								);
							})}
						</ul>
					)
				}
			</div>

			{
				heroImage && (
					<div
						class="lg:col-span-2"
						data-reveal="up"
						data-reveal-delay="2"
					>
						<div class="relative mx-auto w-[13rem] sm:w-[16rem] md:w-[18rem] lg:w-auto lg:max-w-none aspect-[4/5] sm:aspect-[3/4] lg:aspect-[4/5] rounded-2xl overflow-hidden ring-1 ring-gold/30 shadow-2xl lg:shadow-gold/10 lg:rotate-[1.5deg] lg:hover:rotate-0 transition-transform duration-500 ease-out">
							<Image
								src={heroImage.src}
								alt={heroImage.alt}
								widths={[240, 360, 480, 720, 960, 1200]}
								sizes="(max-width: 640px) 13rem, (max-width: 1024px) 18rem, 45vw"
								loading="lazy"
								class="w-full h-full object-cover"
								style={`object-position: ${heroImage.objectPosition ?? "center top"};`}
							/>
							<div
								class="absolute inset-0 bg-gradient-to-t from-navy/40 via-transparent to-transparent pointer-events-none"
								aria-hidden="true"
							></div>
							<span
								class="absolute -bottom-3 -left-3 sm:-bottom-4 sm:-left-4 px-3 py-1.5 rounded-full bg-navy ring-1 ring-gold/40 text-[0.7rem] sm:text-xs uppercase tracking-[0.16em] text-gold font-semibold shadow-lg"
								aria-hidden="true"
							>
								Dra. Sacha
							</span>
						</div>
					</div>
				)
			}
		</div>
	</div>
</section>
