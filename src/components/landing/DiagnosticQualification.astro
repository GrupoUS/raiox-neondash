---
import { Check } from "lucide-react";

interface Props {
	headline: string;
	intro?: string;
	items: string[];
}

const { headline, intro, items } = Astro.props;
---

<section class="py-16 md:py-20 px-6 lg:px-8">
	<div class="max-w-3xl mx-auto">
		<div class="glass-card rounded-2xl p-8 md:p-10">
			<h2
				class="font-serif text-2xl md:text-3xl lg:text-4xl font-bold mb-4"
				data-reveal="up"
			>
				<span class="text-gradient-gold">{headline}</span>
			</h2>

			{
				intro && (
					<p
						class="text-base md:text-lg text-muted mb-8"
						data-reveal="up"
						data-reveal-delay="1"
					>
						{intro}
					</p>
				)
			}

			<ul class="space-y-4 list-none">
				{
					items.map((item, index) => (
						<li
							class="flex items-start gap-4"
							data-reveal="up"
							data-reveal-delay={String(Math.min(index + 2, 6))}
						>
							<span class="shrink-0 mt-1 size-6 rounded-full bg-[color-mix(in_srgb,var(--color-gold)_22%,transparent)] flex items-center justify-center text-gold">
								<Check aria-hidden="true" width={14} height={14} strokeWidth={3} />
							</span>
							<p class="text-base md:text-lg text-foreground leading-relaxed">
								{item}
							</p>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
