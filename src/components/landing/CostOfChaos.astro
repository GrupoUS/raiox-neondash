---
import {
	AlertTriangle,
	Briefcase,
	CalendarX,
	EyeOff,
	MessageCircleOff,
} from "lucide-react";

const ICONS = {
	CalendarX,
	MessageCircleOff,
	EyeOff,
	Briefcase,
} as const;

type IconKey = keyof typeof ICONS;

interface CostItem {
	icon: string;
	label: string;
	description: string;
}

interface Props {
	headline?: string;
	items: CostItem[];
}

const { headline = "4 sintomas de quem está crescendo no escuro", items } =
	Astro.props;

function resolveIcon(name: string) {
	return name in ICONS ? ICONS[name as IconKey] : AlertTriangle;
}
---

<section class="py-16 sm:py-20 md:py-24 lg:py-28 px-5 sm:px-6 lg:px-8 bg-navy-light/30">
	<div class="max-w-5xl lg:max-w-6xl mx-auto">
		<h2
			class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-12 md:mb-16"
			data-reveal="up"
		>
			<span class="text-gradient-gold">{headline}</span>
		</h2>

		<ul class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 list-none">
			{
				items.map((item, index) => {
					const Icon = resolveIcon(item.icon);
					return (
						<li
							class="group glass-card card-hover-lift rounded-2xl p-7 md:p-8 lg:p-9 flex flex-col items-start gap-4 hover:ring-1 hover:ring-gold/40"
							data-reveal="up"
							data-reveal-delay={String(Math.min(index + 1, 6))}
						>
							<div class="size-14 rounded-2xl bg-gold-soft flex items-center justify-center text-gold ring-1 ring-gold/30">
								<Icon aria-hidden="true" width={28} height={28} />
							</div>
							<div class="flex-1 min-w-0">
								<h3 class="font-serif text-xl md:text-2xl font-bold text-foreground mb-2">
									{item.label}
								</h3>
								<p class="text-sm md:text-base text-muted leading-relaxed">
									{item.description}
								</p>
							</div>
						</li>
					);
				})
			}
		</ul>
	</div>
</section>
