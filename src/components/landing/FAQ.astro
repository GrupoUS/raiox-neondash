---
import { Minus, Plus } from "lucide-react";

interface FaqItem {
	q: string;
	a: string;
}

interface Props {
	headline: string;
	subhead?: string;
	items: FaqItem[];
}

const { headline, subhead, items } = Astro.props;
---

<section class="py-16 sm:py-20 md:py-24 lg:py-28 px-5 sm:px-6 lg:px-8">
	<div class="max-w-3xl lg:max-w-5xl mx-auto">
		<header class="text-center mb-10 md:mb-14">
			<h2
				class="font-serif text-[1.75rem] sm:text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4"
				data-reveal="up"
			>
				<span class="text-gradient-gold">{headline}</span>
			</h2>
			{
				subhead && (
					<p
						class="text-base md:text-lg text-muted max-w-2xl mx-auto"
						data-reveal="up"
						data-reveal-delay="1"
					>
						{subhead}
					</p>
				)
			}
		</header>

		<ul class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-4 list-none">
			{
				items.map((item, index) => (
					<li
						data-reveal="up"
						data-reveal-delay={String(Math.min(index + 1, 6))}
					>
						<details class="faq-item glass-card rounded-2xl px-5 md:px-6 group">
							<summary class="faq-summary flex items-center justify-between gap-4 py-4 md:py-5 cursor-pointer list-none text-left text-base md:text-lg font-semibold text-foreground min-h-[3rem]">
								<span class="flex-1">{item.q}</span>
								<span
									class="faq-icon shrink-0 size-10 rounded-full border border-gold/40 flex items-center justify-center text-gold transition-colors duration-200"
									aria-hidden="true"
								>
									<Plus className="faq-icon-closed" width={18} height={18} />
									<Minus className="faq-icon-open" width={18} height={18} />
								</span>
							</summary>
							<div class="faq-content">
								<div class="overflow-hidden">
									<p class="pb-5 md:pb-6 text-[0.95rem] md:text-base text-muted leading-relaxed">
										{item.a}
									</p>
								</div>
							</div>
						</details>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	/* Cardinal #8 — animate grid-template-rows, never height */
	.faq-item .faq-content {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 200ms ease-in-out;
	}
	.faq-item[open] .faq-content {
		grid-template-rows: 1fr;
	}
	.faq-summary::-webkit-details-marker {
		display: none;
	}
	.faq-summary::marker {
		display: none;
	}
	/* +/- icon swap on [open] — pure CSS */
	.faq-item .faq-icon-open {
		display: none;
	}
	.faq-item[open] .faq-icon-closed {
		display: none;
	}
	.faq-item[open] .faq-icon-open {
		display: block;
	}
	@media (prefers-reduced-motion: reduce) {
		.faq-item .faq-content {
			transition: none;
		}
	}
</style>
