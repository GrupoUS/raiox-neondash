{
  "name": "gp-us-harmonic-pascal",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check:external-urls": "node scripts/check-external-urls.mjs",
    "smoke-test": "node scripts/smoke-test.mjs",
    "lint": "bunx biome check src astro.config.mjs && bunx oxlint src --ignore-pattern 'src/layouts/*'",
    "lint:fix": "bunx biome check src astro.config.mjs --write && bunx oxlint src --ignore-pattern 'src/layouts/*' --fix --fix-suggestions",
    "lighthouse:audit": "node scripts/lighthouse-audit.mjs",
    "predeploy": "bun run lint && bunx astro check && bun run build",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.1",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.8",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "chrome-launcher": "^1.2.1",
    "lefthook": "^2.1.4",
    "lighthouse": "^13.0.3",
    "oxlint": "^1.57.0"
  }
}